  "Event": [
    {
      "Name": "CanAddItemV2",
      "Description": "能否添加物品，能添加多少物品\n\t  可重载并自定义\n\t  DS 被调用\n\t  \n\t  能通过此事件，决定调用 AddItemV2 时，允许添加多少物品。\n\t  即使此事件允许添加物品，也可能因为其它限制因素导致物品添加数量减少或添加失败。\n\t  部分强制添加物品的情形，会跳过此事件。\n\t ",
      "Params": [
        {
          "Name": "ItemID",
          "Type": "int32 ",
          "Description": "物品ID",
          "Redirect": ""
        },
        {
          "Name": "Count",
          "Type": "int32",
          "Description": "需要添加的物品数量",
          "Redirect": ""
        }
      ],
      "Return": [
        {
          "Name": "",
          "Type": "int32 ",
          "Description": "允许添加的物品数量，如果等于 Count 表示允许添加所有需要的物品",
          "Redirect": ""
        }
      ]
    },
    {
      "Name": "CanAddItemByDefineIDV2",
      "Description": "能否添加物品，能添加多少物品\n\t  可重载并自定义\n\t  DS 被调用\n\t  \n\t  能通过此事件，决定添加某个实例物品时，允许添加多少物品。\n\t  此接口针对具体实例，调用AddItemV2、调用AddItemByDefineIDV2、物品转移等情形都可能触发此事件。\n\t  单次调用 AddItemV2 可能触发多次针对不同实例的 CanAddItemByDefineIDV2 判断。\n\t  即使此事件允许添加物品，也可能因为其它限制因素导致物品添加数量减少或添加失败。\n\t  部分强制添加物品的情形，会跳过此事件。\n\t ",
      "Params": [
        {
          "Name": "DefineID",
          "Type": "FItemDefineID & ",
          "Description": "",
          "Redirect": ""
        },
        {
          "Name": "Count",
          "Type": "int32",
          "Description": "需要添加的物品数量",
          "Redirect": ""
        }
      ],
      "Return": [
        {
          "Name": "",
          "Type": "int32 ",
          "Description": "允许添加的物品数量，如果等于 Count 表示允许添加所有需要的物品",
          "Redirect": ""
        }
      ]
    },
    {
      "Name": "OnAddItemV2",
      "Description": "当添加物品实例后回调\n\t  可重载并自定义\n\t  DS 被调用\n\t  \n\t  当物品实例被成功添加时触发此事件。\n\t  单次 AddItemV2 可能触发多次针对不同实例的 OnAddItem 调用（生成多个堆叠的情况）。\n\t  如果物品触发了自动装备，可能装备相关事件会先于 OnAddItemV2 被触发。\n\t ",
      "Params": [
        {
          "Name": "ItemDefineID",
          "Type": "FItemDefineID & ",
          "Description": "物品DefineID",
          "Redirect": ""
