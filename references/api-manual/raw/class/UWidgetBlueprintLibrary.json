    {
      "Name": "DetectDrag",
      "Description": "Ask Slate to detect if a user starts dragging in this widget later.  Slate internally tracks the movement\n\t  and if it surpasses the drag threshold, Slate will send an OnDragDetected event to the widget.\n\t ",
      "Params": [
        {
          "Name": "Reply",
          "Type": "FEventReply & ",
          "Description": "",
          "Redirect": ""
        },
        {
          "Name": "WidgetDetectingDrag",
          "Type": "UWidget * ",
          "Description": "Detect dragging in this widget",
          "Redirect": ""
        },
        {
          "Name": "DragKey",
          "Type": "FKey",
          "Description": "    This button should be pressed to detect the drag",
          "Redirect": ""
        }
      ],
      "Return": [
        {
          "Name": "",
          "Type": "FEventReply ",
          "Description": "",
          "Redirect": ""
        }
      ]
    },
    {
      "Name": "DetectDragIfPressed",
      "Description": "Given the pointer event, emit the DetectDrag reply if the provided key was pressed.\n\t  If the DragKey is a touch key, that will also automatically work.",
      "Params": [
        {
          "Name": "PointerEvent",
          "Type": "FPointerEvent & ",
          "Description": "The pointer device event coming in.",
          "Redirect": ""
        },
        {
          "Name": "WidgetDetectingDrag",
          "Type": "UWidget * ",
          "Description": "Detect dragging in this widget.",
          "Redirect": ""
        },
        {
          "Name": "DragKey",
          "Type": "FKey",
          "Description": "    This button should be pressed to detect the drag, won't emit the DetectDrag FEventReply unless this is pressed.",
          "Redirect": ""
        }
      ],
      "Return": [
        {
          "Name": "",
          "Type": "FEventReply ",
          "Description": "",
          "Redirect": ""
        }
