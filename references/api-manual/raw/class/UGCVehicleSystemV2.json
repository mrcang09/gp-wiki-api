          "Description": "载具",
          "Redirect": ""
        }
      ],
      "Return": null
    },
    {
      "Name": "Respawn",
      "Description": "重生载具\n重生将创建新载具，旧的载具将被销毁不再可用\n生效范围：服务器",
      "Params": [
        {
          "Name": "Vehicle",
          "Type": "ASTExtraVehicleBase",
          "Description": "载具",
          "Redirect": ""
        }
      ],
      "Return": [
        {
          "Name": "",
          "Type": "ASTExtraVehicleBase",
          "Description": "重生后的新载具。若为nil，表示操作失败，新的载具不会创建、旧的载具也不会销毁。",
          "Redirect": ""
        }
      ]
    },
    {
      "Name": "EnterVehicle",
      "Description": "玩家角色进入载具\n生效范围：服务器&客户端(客户端仅能操作自己的玩家角色)",
      "Params": [
        {
          "Name": "Player",
          "Type": "PlayerPawn | PlayerController @玩家角色或玩家PlayerController",
          "Description": "玩家角色或玩家PlayerController",
          "Redirect": ""
        },
        {
          "Name": "Vehicle",
          "Type": "ASTExtraVehicleBase",
          "Description": "载具",
          "Redirect": ""
        },
        {
          "Name": "SeatIndex",
          "Type": "int",
          "Description": "座位索引(0为驾驶位，-1表示尝试进入任意空位置)。可缺省，默认-1。",
          "Redirect": ""
        },
        {
          "Name": "IsForce",
          "Type": "bool",
          "Description": "是否无视距离和阻挡(仅服务器调用支持此项)。可缺省，默认 false",
          "Redirect": ""
        }
      ],
      "Return": [
        {
          "Name": "",
          "Type": "bool",
          "Description": "服务器:是否成功进入 | 客户端:返回值无意义",
          "Redirect": ""
        }
      ]
    },
