{
  "Name": "UGCVehicleSystemV2",
  "Description": "载具系统接口库V2",
  "Variables": null,
  "Functions": [
    {
      "Name": "SpawnVehicle",
      "Description": "使用蓝图路径生成载具\n不要在 Spawn 之后立马修改载具位置，等载具落地停稳后再修改，不然位置修改会失败（如果有类似需求，建议直接创建在对应点）\n生效范围：服务器",
      "Params": [
        {
          "Name": "VehiclePath",
          "Type": "string",
          "Description": "载具蓝图路径，格式示例：\"/Game/Arts_PlayerBluePrints/Vehicle/VH_Buggy/BP_VH_Buggy.BP_VH_Buggy_C\"",
          "Redirect": ""
        },
        {
          "Name": "Location",
          "Type": "Vector",
          "Description": "生成位置",
          "Redirect": ""
        },
        {
          "Name": "Rotation",
          "Type": "Rotator",
          "Description": "旋转。可缺省，默认无旋转",
          "Redirect": ""
        },
        {
          "Name": "SnapFloor",
          "Type": "bool",
          "Description": "是否贴地。可缺省，默认 true",
          "Redirect": ""
        },
        {
          "Name": "IsForce",
          "Type": "bool",
          "Description": "是否无视碰撞强行生成。 可缺省，默认 false",
          "Redirect": ""
        }
      ],
      "Return": [
        {
          "Name": "",
          "Type": "ASTExtraVehicleBase",
          "Description": "载具",
          "Redirect": ""
        }
      ]
    },
    {
      "Name": "DestroyVehicle",
